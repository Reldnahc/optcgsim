{
  "repo": "Reldnahc/optcgsim",
  "labels": {
    "ensure": true,
    "include_status": false,
    "defaults": ["story"]
  },
  "project": {
    "owner": "Reldnahc",
    "number": 1,
    "field_mapping": {
      "Status": {
        "source": "status",
        "option_map": {
          "generated": "Backlog",
          "approved": "Todo",
          "in_progress": "In Progress",
          "in_review": "In Review",
          "changes_requested": "Changes Requested",
          "blocked": "Blocked",
          "done": "Done",
          "replaced": "Canceled"
        }
      },
      "Priority": {
        "source": "priority"
      },
      "Area": {
        "source": "area"
      },
      "Type": {
        "source": "type"
      },
      "Spec Version": {
        "source": "spec_version"
      },
      "Story ID": {
        "source": "id"
      },
      "Estimate": {
        "source": "board.estimate"
      },
      "Iteration": {
        "source": "board.iteration"
      }
    }
  }
}
