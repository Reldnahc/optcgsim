{
  "name": "@optcg/engine-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "corepack pnpm --filter @optcg/types run build && corepack pnpm exec tsc -p tsconfig.build.json",
    "typecheck": "corepack pnpm exec tsc -p tsconfig.json",
    "lint": "corepack pnpm exec eslint src",
    "test": "corepack pnpm exec vitest run --passWithNoTests",
    "test:watch": "corepack pnpm exec vitest --passWithNoTests",
    "coverage": "corepack pnpm exec vitest run --coverage --passWithNoTests"
  }
}
